<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication1.ViewModels"
        x:Class="AvaloniaApplication1.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Tableaux de prévisions - MFQ">

    <Grid ColumnDefinitions="*, 200" RowDefinitions="Auto, *, 220">
        
        <!-- HEADER AVEC DÉGRADÉ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Height="150">
            
            <Border.Background>
                <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                    <GradientStop Offset="0" Color="#E8E8E8" />
                    <GradientStop Offset="1" Color="#B0B0B0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Logo -->
                <Image Grid.Column="0" Source="/Assets/LogoMFQ.png" Width="150" Margin="20"/>
                
                <!-- Titres Dynamiques -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Prévisions économiques" FontSize="28" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock Text="{Binding Greeting}" FontSize="20" FontStyle="Italic" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Boutons de droite -->
                <StackPanel Grid.Column="2" Margin="20" Spacing="5" VerticalAlignment="Center">
                    <Button Content="Trimestriel" Width="120" HorizontalContentAlignment="Center"/>
                    <Button Content="Annuel" Width="120" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Border>

        <!-- ZONE CENTRALE DYNAMIQUE (BODY) -->
        <Border Grid.Row="1" Grid.Column="0" Margin="10" Background="White" CornerRadius="5" BoxShadow="2 2 10 0 #40000000">
            <ContentControl Content="{Binding CurrentPageContent}" />
            <!-- Ici s'affichera votre UserControl d'accueil avec les icônes -->
        </Border>

        <!-- BARRE LATÉRALE BLEUE -->
        <Border Grid.Row="1" Grid.Column="1" Background="#4A6A8A" Margin="0,0,0,0" />

        <!-- FOOTER BLEU (FILTRES ET BOUTONS) -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#4A6A8A" Padding="20">
            <Grid ColumnDefinitions="Auto, Auto, Auto, *">
                <!-- Boutons d'action -->
                <StackPanel Grid.Column="0" Spacing="10">
                    <Button Content="Rechercher" Width="120"/>
                    <Button Content="Imprimer" Width="120"/>
                </StackPanel>

                <!-- Filtres (Checkboxes) -->
                <StackPanel Grid.Column="1" Margin="40,0" VerticalAlignment="Center">
                    <TextBlock Text="Filtres :" Foreground="White" Margin="0,0,0,5"/>
                    <CheckBox Content="Tableau" Foreground="White"/>
                    <CheckBox Content="Description" Foreground="White"/>
                </StackPanel>

                <!-- Menus Déroulants (ComboBox) -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Right" Spacing="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Année début : " Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox Width="100" PlaceholderText="2022"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Trimestre : " Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox Width="100" PlaceholderText="IV"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
